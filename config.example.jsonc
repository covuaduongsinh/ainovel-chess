{
  // Provider, model và mức độ suy luận mặc định sử dụng.
  // ★ Giá trị provider là tên key trong mục providers bên dưới (một "con trỏ"), không phải tên giao thức——
  //   Đổi provider phải đảm bảo providers có mục cùng tên, không thì khởi động sẽ báo "chưa cấu hình thông tin xác thực".
  //   Chuyển đổi qua panel /model trong lúc chạy sẽ ghi lại vào cấu hình toàn cục ~/.ainovel/config.json.
  "provider": "openrouter",
  "model": "google/gemini-2.5-flash",
  // Tùy chọn. Mức độ suy luận mặc định: off / low / medium / high / xhigh / max.
  // Bỏ qua hoặc chuỗi rỗng = không ghi đè, giữ nguyên mặc định của model/provider.
  "reasoning_effort": "medium",

  // Kho thông tin xác thực provider. Key tự đặt, dùng làm đích cho trường provider ở trên.
  // Provider đã biết (openai/anthropic/gemini/openrouter/deepseek/qwen/glm/grok/mimo/ollama/bedrock)
  // có thể bỏ qua type; proxy tùy chỉnh phải khai báo type để chỉ định giao thức API.
  "providers": {
    "openrouter": {
      "api_key": "sk-or-v1-xxx",
      "base_url": "https://openrouter.ai/api/v1",
      // Tùy chọn. Khai báo danh sách model cho panel /model; bỏ qua thì fallback về các model cùng provider đã dùng trong config.
      "models": ["google/gemini-3.0-flash", "google/gemini-3.1-pro"],
      // Tùy chọn. Tham số bổ sung truyền thẳng vào mỗi request của provider (tham số sampling như temperature/top_p/
      // min_p, hoặc key riêng của nhà cung cấp như chat_template_kwargs để bật think của nvidia), gộp vào request body.
      // Chỉ có tác dụng với provider tương thích OpenAI (openrouter/deepseek/qwen/glm/grok/ollama…);
      // type:"openai" sẽ lọc theo danh sách tham số chính thức. Giá trị do người dùng tự chịu trách nhiệm.
      "extra_body": { "temperature": 0.8, "min_p": 0.05 },
      // Tùy chọn. Cấu hình cấp provider, truyền thẳng vào lớp HTTP client (không phải request body), dùng khi cần
      // tùy chỉnh User-Agent / headers / anthropic_beta cho proxy.
      "extra": {
        "user_agent": "my-client/1.0",
        "headers": { "X-Custom-Client": "my-client" }
      }
    },
    "anthropic": {
      "api_key": "sk-ant-xxx",
      "models": ["claude-sonnet-4", "claude-opus-4"]
    },
    "claude-code": {
      // Tích hợp Claude Code: dùng gói thuê bao qua một CẦU NỐI NỘI BỘ tương thích giao thức Anthropic.
      // Cách HỢP LỆ: cầu nối đi qua Claude Agent SDK chính thức (vd Meridian: `npm i -g @rynfar/meridian`,
      // `claude login`, `meridian` → http://127.0.0.1:3456). KHÔNG dùng proxy phát lại token OAuth thẳng
      // lên api.anthropic.com (vi phạm điều khoản, đã bị chặn).
      // api_key: cầu nối bỏ qua giá trị này, nhưng litellm đòi khác rỗng → điền giữ chỗ bất kỳ (vd "sk-local").
      // Muốn trả theo token thay vì thuê bao: đặt base_url = "https://api.anthropic.com" và điền api_key sk-ant-... thật.
      "type": "anthropic",
      "api_key": "sk-local",
      "base_url": "http://127.0.0.1:3456",
      "models": ["claude-opus-4-8", "claude-opus-4-7", "claude-sonnet-4-6", "claude-haiku-4-5"]
    },
    "ollama": {
      // ollama / bedrock / proxy tùy chỉnh khai báo type có thể bỏ qua api_key
      // base_url cần có /v1 (endpoint tương thích OpenAI của ollama nằm dưới /v1)
      "base_url": "http://localhost:11434/v1",
      "models": ["qwen3:14b"]
    },
    "claude-code-proxy": {
      // Proxy Anthropic tùy chỉnh. Nếu upstream chỉ cho phép truy cập qua Claude Code client,
      // dùng extra để truyền user_agent / anthropic_beta / headers.
      // base_url không cần /v1.
      "type": "anthropic",
      "api_key": "sk-xxx",
      "base_url": "https://proxy.example.com",
      "models": ["claude-sonnet-4-6"],
      "extra": {
        "user_agent": "claude-code/2.1.183",
        "anthropic_beta": "claude-code-20250219",
        "headers": {
          "X-Stainless-Lang": "js",
          "X-Stainless-Package-Version": "0.94.0",
          "X-Stainless-Runtime": "node"
        }
      }
    },
    "codex-proxy": {
      // Proxy OpenAI/NewAPI tùy chỉnh. Nếu upstream chỉ cho phép truy cập qua Codex client,
      // dùng extra để ghi đè User-Agent và truyền header nhận diện Codex.
      // base_url điền theo địa chỉ thực của proxy; giao thức OpenAI thường cần /v1.
      "type": "openai",
      "api_key": "sk-xxx",
      "base_url": "https://proxy.example.com/v1",
      "models": ["gpt-5.4", "gpt-5.4-mini", "MiniMax-M3"],
      // Tùy chọn. Endpoint giao thức OpenAI: chat (mặc định /v1/chat/completions)/
      // responses (/v1/responses). Proxy kiểu Codex thường cần responses.
      "api": "responses",
      "extra": {
        "user_agent": "codex-tui/0.142.3 (Mac OS 26.5.1; arm64) Apple_Terminal/470.2 (codex-tui; 0.142.3)",
        "headers": {
          "Originator": "codex-tui",
          "Session_id": "replace-with-random-session-id",
          "X-Codex-Turn-Metadata": "replace-with-random-turn-metadata"
        }
      }
    }
  },

  // Tùy chọn. Ghi đè model mặc định theo từng vai trò; vai trò chưa cấu hình dùng model ở trên.
  // reasoning_effort cũng có thể ghi đè theo vai trò; chưa cấu hình thì kế thừa reasoning_effort cấp trên.
  // Vai trò: coordinator / architect / writer / editor. fallbacks thử lần lượt khi model chính thất bại.
  // Lưu ý: provider ở đây cũng là "con trỏ", phải trỏ vào key tồn tại trong providers.
  // Mẹo: gõ "/model auto" (TUI) hoặc nút "Tự chọn" (Web) sẽ áp preset Claude cân bằng vào roles bên dưới:
  //   writer/architect → claude-opus-4-8 (high), coordinator/editor → claude-sonnet-4-6 (medium), qua provider "claude-code".
  // "roles": {
  //   "writer": {
  //     "provider": "anthropic",
  //     "model": "claude-sonnet-4",
  //     "reasoning_effort": "high",
  //     "fallbacks": [{ "provider": "openrouter", "model": "google/gemini-3.0-pro" }]
  //   },
  //   "architect": { "provider": "openrouter", "model": "google/gemini-3.1-pro" }
  // },

  // Phong cách viết: default / suspense / fantasy / romance.
  "style": "default"

  // Tùy chọn. Chỉ định tường minh kích thước cửa sổ context dùng cho nén ngữ cảnh. Bỏ qua / 0 = tự động phân tích theo tên model
  // (registry tra cứu được dùng cửa sổ thật, không tra được thì mặc định 200k). Cấu hình thì ưu tiên dùng:
  // có thể chỉ định cửa sổ thật cho model tùy chỉnh không có trong registry, hoặc ghim cửa sổ danh nghĩa 1M
  // xuống 300k để kích hoạt nén sớm, tránh nén trong vùng chú ý suy giảm. Chỉ ảnh hưởng ngưỡng nén, không thay đổi độ dài request API thực tế.
  // "context_window": 300000

  // Tùy chọn. Ngân sách chi phí mỗi cuốn sách (thư mục output), cầu dao bảo hiểm chạy không giám sát. book_usd > 0 mới kích hoạt.
  // Khi tổng chi phí đạt warn_ratio thì cảnh báo nhưng không dừng; khi đạt 100% thì dừng ưu nhã sau khi
  // sub-agent hiện tại hoàn thành (hard_stop=true thì dừng ngay khi vượt ngưỡng). Sau khi dừng chỉ cần tăng book_usd là tiếp tục được.
  // Lưu ý: model tùy chỉnh không có trong registry và provider không tự báo cost thì ngân sách vô hiệu.
  // "budget": {
  //   "book_usd": 50,
  //   "warn_ratio": 0.8,
  //   "hard_stop": false
  // },

  // Tùy chọn. Cảnh báo không giám sát, mặc định bật (thông báo desktop macOS osascript / Linux notify-send).
  // Cấu hình command thì chuyển sang lệnh tùy chỉnh (push điện thoại đi qua đây): các trường truyền qua biến môi trường
  // $NOTIFY_TITLE / $NOTIFY_BODY / $NOTIFY_KIND / $NOTIFY_LEVEL, JSON đầy đủ đồng thời ghi vào stdin.
  // events lọc tùy chọn: run_end (hoàn thành/dừng) / repeat (lệnh lặp, nghi ngờ vòng lặp rỗng) / budget (ngân sách).
  // "notify": {
  //   "enabled": true,
  //   // Tiêu đề/nội dung có dấu cách và ký tự đặc biệt, phải dùng --data-urlencode, không ghép vào URL path hoặc HTTP header.
  //   // Bark (iOS):         "command": "curl -s --data-urlencode \"title=$NOTIFY_TITLE\" --data-urlencode \"body=$NOTIFY_BODY\" https://api.day.app/<key>"
  //   // ntfy (iOS/Android): "command": "curl -s -G --data-urlencode \"title=$NOTIFY_TITLE\" --data-urlencode \"message=$NOTIFY_BODY\" ntfy.sh/<topic>/publish"
  //   "events": ["run_end", "repeat", "budget"]
  // }
}
